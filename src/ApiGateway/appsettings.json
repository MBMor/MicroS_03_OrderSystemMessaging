{
  "Jwt": {
    "Authority": "http://localhost:18080/realms/order-system",
    "Audience": "order-system-api",
    "ValidIssuer": "http://localhost:18080/realms/order-system",
    "RequireHttpsMetadata": false
  },
  "ReverseProxy": {
    "Routes": {
      "orders-root-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/v1/orders"
        }
      },
      "orders-catch-all-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/v1/orders/{**catch-all}"
        }
      },
      "inventory-root-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/v1/inventory-items"
        }
      },
      "inventory-catch-all-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/v1/inventory-items/{**catch-all}"
        }
      },
      "notifications-root-route": {
        "ClusterId": "notifications-cluster",
        "Match": {
          "Path": "/api/v1/notifications"
        }
      },
      "notifications-catch-all-route": {
        "ClusterId": "notifications-cluster",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "orders-cluster": {
        "Destinations": {
          "orders-api": {
            "Address": "http://orders-api:8080/"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "inventory-api": {
            "Address": "http://inventory-api:8080/"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "notifications-api": {
            "Address": "http://notifications-api:8080/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Information",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*"
}