{
  "App": {
    "ServiceName": "Notifications Service"
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "ExchangeName": "ordersystem.events"
  },
  "RabbitMQTopology": {
    "DeadLetterExchangeName": "ordersystem.events.dlx",
    "OrderCreatedQueueName": "notifications.order-created",
    "OrderCreatedDeadLetterQueueName": "notifications.order-created.dlq",
    "StockReservedQueueName": "notifications.stock-reserved",
    "StockReservedDeadLetterQueueName": "notifications.stock-reserved.dlq",
    "StockReservationFailedQueueName": "notifications.stock-reservation-failed",
    "StockReservationFailedDeadLetterQueueName": "notifications.stock-reservation-failed.dlq",
    "InitializationRetryDelaySeconds": 5
  },
  "EventNotificationConsumers": {
    "PrefetchCount": 10,
    "ConnectionRetryDelaySeconds": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}